---
import { ClientRouter } from "astro:transitions";
import Header from "@/components/Header.astro";
import PostHog from "@/components/PostHog.astro";
import Analytics from "@vercel/analytics/astro";
import { cn } from "@/lib/utils";
import "@/styles/global.css";

interface Props {
  title: string;
  description: string;
  image?: string;
  className?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = "/static/blog-placeholder.png", className } = Astro.props;
---

<html lang="en" transition:animate="none">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="color-scheme" content="light dark" />

    <script is:inline>
      (function () {
        function getTheme() {
          return (
            localStorage.getItem("theme") ||
            (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light")
          );
        }
        function applyTheme() {
          var isDark = getTheme() === "dark";
          var el = document.documentElement;
          el.classList.toggle("dark", isDark);
          el.style.colorScheme = isDark ? "dark" : "light";
          el.style.backgroundColor = isDark ? "#0a0a0a" : "#fafafa";
        }
        applyTheme();
        if (!window.__themeListeners) {
          document.addEventListener("astro:before-swap", function (e) {
            var isDark = getTheme() === "dark";
            e.newDocument.documentElement.classList.toggle("dark", isDark);
            e.newDocument.documentElement.style.colorScheme = isDark ? "dark" : "light";
            e.newDocument.documentElement.style.backgroundColor = isDark ? "#0a0a0a" : "#fafafa";

            // Disable CSS transitions during swap to prevent flash
            // when dark class is briefly toggled (astro#8711)
            var css = document.createElement("style");
            css.appendChild(
              document.createTextNode(
                "*,*::before,*::after{-webkit-transition:none!important;-moz-transition:none!important;-o-transition:none!important;-ms-transition:none!important;transition:none!important}"
              )
            );
            e.newDocument.head.appendChild(css);
            // Remove after the transition frame
            document.addEventListener(
              "astro:after-swap",
              function () {
                requestAnimationFrame(function () {
                  css.remove();
                });
              },
              { once: true }
            );
          });
          document.addEventListener("astro:after-swap", applyTheme);
          window.__themeListeners = true;
        }
      })();
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <link
      rel="preload"
      href="/fonts/geist-variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/geist-mono-variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />

    <Analytics />
    <PostHog />
    <ClientRouter />
  </head>
  <body
    class="font-sans text-zinc-950 antialiased bg-[#fafafa] dark:bg-[#0a0a0a] dark:text-zinc-100"
  >
    <div
      class={cn(
        "mx-auto px-6 prose prose-sm dark:prose-invert prose-zinc max-w-2xl py-16 sm:py-24",
        className,
      )}
    >
      <Header />
      <main transition:animate="none">
        <slot />
      </main>
    </div>
  </body>
</html>
