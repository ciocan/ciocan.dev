---
import { type CollectionEntry } from "astro:content";

type Props = CollectionEntry<"projects">;

const project = Astro.props;
const { name, title, year, url } = project.data;
const { Content } = await project.render();
---

<div class="py-8 border-t border-zinc-200 dark:border-zinc-800">
  <div class="flex items-baseline justify-between gap-4 mb-3">
    <a
      href={url}
      target="_blank"
      class="font-mono text-base font-semibold text-zinc-950 dark:text-zinc-100 hover:text-zinc-500 dark:hover:text-zinc-400 transition-colors no-underline"
    >
      {name}
    </a>
    <span class="text-nowrap text-xs text-zinc-400 dark:text-zinc-600 font-mono">
      {year}
    </span>
  </div>
  <p class="text-sm text-zinc-600 dark:text-zinc-400 font-medium mb-4">
    {title}
  </p>
  <article class="project-description">
    <Content />
  </article>
</div>
